# ... (your other rules) ...

# 1. Ignore everything
*

# 2. Un-ignore directories so git can walk into them
!*/

# 3. Un-ignore files with dots (source code)
!*.*

# 4. CRITICAL: Re-ignore dSYM (even though they have dots)
*.dSYM/
**/*.dSYM/


# 1. Folders & Bundles
.idea/
.vscode/
DerivedData/
.build/
Packages/

# 2. Specific Binary Extensions
*.o
*.obj
*.exe
*.out
*.bin
*.app
*.dll
*.so
*.dylib

# 3. OS Files
.DS_Store

